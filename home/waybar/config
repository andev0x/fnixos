{
  "layer": "top",
  "position": "top",
  "height": 34,
  "spacing": 6,

  "modules-left": ["hyprland/workspaces", "hyprland/window"],
  "modules-center": ["clock"],
  "modules-right": ["cpu", "memory", "pulseaudio", "network", "battery", "tray", "group/power"],

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{icon}",
    "format-icons": {
      "1": "ΎΕι",
      "2": "ΎΚσ",
      "3": "≤░Ιβ",
      "4": "≤░ΥΘ",
      "5": "≤░ΟΕ",
      "urgent": "ΎΒς",
      "focused": "ΎΗΤ",
      "default": "ΎΕΣ"
    }
  },

  "hyprland/window": {
    "format": "{}",
    "max-length": 50,
    "separate-outputs": true
  },

  "clock": {
    "format": "≤░ξΦ {:%H:%M}",
    "format-alt": "≤░Δφ {:%Y-%m-%d}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },

  "cpu": {
    "interval": 2,
    "format": "≤░Ξδ {usage}%",
    "tooltip": false
  },

  "memory": {
    "interval": 5,
    "format": "≤░Ξ╣ {used:0.1f}G",
    "tooltip": false
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "≤░╕Ι",
    "format-icons": {
      "default": ["≤░Χ┐", "≤░ΨΑ", "≤░Χ╛"]
    },
    "on-click": "pavucontrol"
  },

  "network": {
    "format-wifi": "≤░νρ {signalStrength}%",
    "format-ethernet": "≤░ΙΑ {ifname}",
    "format-disconnected": "≤░νφ",
    "format-alt": "{ifname}: {ipaddr}/{cidr}",
    "tooltip-format": "{essid} - {ipaddr}"
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "≤░ΓΕ {capacity}%",
    "format-icons": ["≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"]
  },

  "tray": {
    "spacing": 8
  },

  "group/power": {
    "orientation": "horizontal",
    "modules": ["custom/lock", "custom/reboot", "custom/power"]
  },

  "custom/lock": {
    "format": "ΎΑμ",
    "on-click": "loginctl lock-session"
  },
  "custom/reboot": {
    "format": "≤░εΚ",
    "on-click": "systemctl reboot"
  },
  "custom/power": {
    "format": "≤░Ρξ",
    "on-click": "systemctl poweroff"
  }
}
